{
    "$schema": "https://ui.shadcn.com/schema/registry.json",
    "name": "sf-pipeline",
    "homepage": "https://github.com/jawills/sf-pipeline",
    "items": [
      {
        "name": "ci-setup",
        "type": "registry:item",
        "title": "Production Deploy",
        "description": "Deploy changes from a PR to production.",
        "files": [
          {
            "path": "ci-setup/incremental-deploy/action.yml",
            "type": "registry:file",
            "target": "~/.github/actions/incremental-deploy/action.yml"
          },
          {
            "path": "ci-setup/deploy-production.yml",
            "type": "registry:file",
            "target": "~/.github/workflows/deploy-production.yml"
          },
          {
            "path": "ci-setup/validate-production.yml",
            "type": "registry:file",
            "target": "~/.github/workflows/validate-production.yml"
          }
        ]
      }
    ]
  }